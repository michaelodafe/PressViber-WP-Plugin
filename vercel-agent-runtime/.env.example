# -----------------------------------------------------------------------
# AI Vibe Builder — Vercel Agent Runtime Configuration
# -----------------------------------------------------------------------

# Shared secret between WordPress and this runtime (required).
# Set this in both your WordPress wp-config.php (AIVB_AGENT_RUNTIME_SECRET)
# and here in Vercel env vars.
AIVB_AGENT_RUNTIME_SECRET=replace-with-a-long-random-secret

# -----------------------------------------------------------------------
# Provider API Keys — set whichever provider(s) you want to use.
# The runtime picks the first configured provider in this order:
#   1. Custom (any OpenAI-compatible API, e.g. DeepSeek, Mistral, etc.)
#   2. DeepSeek
#   3. OpenAI
# -----------------------------------------------------------------------

# --- Option 1: Any OpenAI-compatible API (DeepSeek, Mistral, Together, etc.) ---
# Set CUSTOM_API_BASE_URL to the provider's /v1 endpoint.
# E.g. for DeepSeek: https://api.deepseek.com/v1
# E.g. for Mistral:  https://api.mistral.ai/v1
CUSTOM_API_KEY=
CUSTOM_API_BASE_URL=https://api.deepseek.com/v1
CUSTOM_MODEL=deepseek-chat

# --- Option 2: DeepSeek (via official @ai-sdk/deepseek adapter) ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Option 3: OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------------------
# Default model slug — matches WordPress model selector values.
# Used when the WordPress plugin doesn't specify a model.
# Values: "deepseek", "gpt5_4", "custom"
# -----------------------------------------------------------------------
AIVB_DEFAULT_MODEL=deepseek
